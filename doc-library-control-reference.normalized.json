            "table": {
              "cw": [
                null,
                40
              ],
              "cwu": [
                null,
                "%"
              ]
            }
          }
        },
        {
          "DisplayName": "",
          "FieldName": "__CUSTOM_FIELD_LABEL__",
          "Field": "__CUSTOM_FIELD_NAME__"
        }
      ]
