          "layoutRules": ["card_container", "grid_row", "section_spacing"],
          "actionBindings": [],
          "fallback": { "allowed": true, "rule": "If Business Justification field is not in base list, add it before generation or document exact deferral." },
          "validationRules": ["section_exists", "data_binding_present"],
          "passCondition": "Justification and budget context are present."
        },
        {
          "id": "payment_contract_information",
          "title": "Payment & Contract Information",
          "status": "required",
          "controls": ["container", "grid", "field", "dynamic-field", "text"],
          "dataSources": ["Vendors"],
          "requiredFields": ["Payment Terms", "Contract Status", "Renewal Date", "Tax Review Status", "Bank Info Status"],
          "matchText": ["Payment & Contract Information", "Payment Terms", "Contract Status", "Renewal Date"],
          "layoutRules": ["card_container", "grid_row", "section_spacing"],
          "actionBindings": [],
          "fallback": { "allowed": false, "rule": "Payment and contract section is required." },
