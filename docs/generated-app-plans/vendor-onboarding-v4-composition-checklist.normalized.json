{
  "application": "Vendor Onboarding & Compliance Management",
  "version": "v4",
  "sourceSpec": "docs/generated-app-plans/vendor-onboarding-compliance-ui-implementation-spec.md",
  "contractType": "pre_generation_composition_checklist",
  "rules": [
    "do_not_generate_package_before_approval",
    "implement_required_sections_or_defer_with_reason",
    "strict_visual_app_quality_required_after_generation",
    "import_success_is_not_app_quality_success"
  ],
  "pages": [
    {
      "id": "vendor_management_dashboard",
      "title": "Vendor Management Dashboard",
      "type": "dashboard",
      "required": true,
      "sections": [
        {
          "id": "header_action_area",
          "title": "Header/action area",
          "status": "required",
          "controls": ["container", "grid", "text", "button"],
          "dataSources": ["Vendors"],
          "requiredFields": [],
          "matchText": ["Vendor Management Dashboard", "Monitor onboarding", "New Vendor Request", "View Compliance Queue"],
          "layoutRules": ["safe_padding", "grid_row", "section_spacing"],
          "actionBindings": ["New Vendor Request", "View Compliance Queue"],
          "fallback": { "allowed": true, "rule": "If navigation action shape is not safe, render inactive navigation notes and record reason." },
          "validationRules": ["section_exists", "controls_present", "action_bindings_present", "no_placeholder_content"],
          "passCondition": "Header title, subtitle, and both actions are present; active buttons have valid bindings."
        },
        {
          "id": "kpi_card_row",
          "title": "KPI card row",
          "status": "required",
          "controls": ["container", "grid", "text", "dynamic-field"],
          "dataSources": ["Vendors", "Vendor Documents", "Compliance Reviews"],
          "requiredFields": ["Vendor Name", "Onboarding Status", "Risk Level", "Review Status", "Expiry Date"],
          "matchText": ["Total Vendors", "Pending Onboarding", "High Risk Vendors", "Expiring Documents"],
          "layoutRules": ["safe_padding", "grid_row", "card_container", "section_spacing"],
          "actionBindings": [],
          "fallback": { "allowed": true, "rule": "If aggregate KPI controls are not safe, use clearly labeled summary cards and document the aggregate binding gap." },
          "validationRules": ["section_exists", "card_structure_present", "not_plain_text_only", "data_binding_present"],
          "passCondition": "Four styled KPI cards exist with labels, values, secondary context, and source-field coverage."
        },
        {
          "id": "onboarding_progress_section",
          "title": "Onboarding completion progress section",
          "status": "required",
          "controls": ["container", "progress-circle", "progress-bar", "text", "dynamic-field"],
          "dataSources": ["Vendors"],
          "requiredFields": ["Onboarding Completion %", "Onboarding Status"],
          "matchText": ["Onboarding Completion", "Average completion"],
          "layoutRules": ["card_container", "section_spacing"],
          "actionBindings": [],
          "fallback": { "allowed": true, "rule": "Use progress bar instead of progress circle if circle binding is not safe." },
          "validationRules": ["section_exists", "data_binding_present", "card_structure_present"],
          "passCondition": "Progress control is in a styled card and bound to completion/status context."
        },
        {
          "id": "urgent_compliance_alert",
          "title": "Urgent compliance alert",
          "status": "required",
          "controls": ["container", "alert", "text", "dynamic-field"],
          "dataSources": ["Vendors", "Vendor Documents", "Compliance Reviews"],
          "requiredFields": ["Vendor Name", "Risk Level", "Compliance Status", "Review Status", "Expiry Date"],
          "matchText": ["Urgent Compliance Risks", "High-risk", "expired", "blocked"],
          "layoutRules": ["card_container", "section_spacing"],
          "actionBindings": [],
          "fallback": { "allowed": false, "rule": "Default alert content is never acceptable." },
          "validationRules": ["section_exists", "no_placeholder_content", "data_binding_present"],
          "passCondition": "Alert has business-specific title/description and references risk or document expiry."
        },
        {
          "id": "onboarding_status_board",
          "title": "Onboarding status board",
          "status": "required",
          "controls": ["kanban", "collection", "container", "text", "dynamic-field", "button"],
          "dataSources": ["Vendors"],
          "requiredFields": ["Vendor Name", "Risk Level", "Compliance Status", "Owner", "Renewal Date", "Last Review Date", "Onboarding Status"],
          "matchText": ["Onboarding Status Board", "Vendor Name", "Risk Level", "Compliance Status"],
          "layoutRules": ["card_container", "grid_row", "section_spacing"],
          "actionBindings": ["View Vendor"],
          "itemTemplate": {
            "controls": ["kanban", "collection"],
            "minDynamicFields": 5,
            "requiredFields": ["Vendor Name", "Risk Level", "Compliance Status", "Owner", "Renewal Date"],
            "requiresActions": true
          },
          "fallback": { "allowed": true, "rule": "Use Collection grouped by status if Kanban grouping is not safe; keep the same dynamic fields and View action." },
          "validationRules": ["section_exists", "item_template_fields_present", "item_actions_present"],
          "passCondition": "Kanban/Collection is bound to Vendors and item template includes required dynamic fields and action."
        },
        {
          "id": "vendors_data_table",
          "title": "Vendors Data table",
          "status": "required",
          "controls": ["data-list"],
          "dataSources": ["Vendors"],
          "requiredFields": ["Vendor Name", "Vendor Type", "Country / Region", "Primary Contact", "Email", "Phone", "Risk Level", "Onboarding Status", "Renewal Date"],
          "matchText": ["Vendor Records", "Vendor Name", "Vendor Type", "Country / Region"],
          "layoutRules": ["safe_padding", "section_spacing"],
          "actionBindings": [],
          "fallback": { "allowed": false, "rule": "Vendors table is required for v4." },
          "validationRules": ["section_exists", "data_table_columns_configured", "field_and_fieldname_required"],
          "passCondition": "Data table is bound to Vendors and every display column has Field and FieldName."
        },
        {
          "id": "quick_links",
          "title": "Quick links",
          "status": "required",
          "controls": ["icon-list", "container", "grid", "button", "text"],
          "dataSources": [],
          "requiredFields": [],
          "matchText": ["Quick Links", "New Vendor", "Compliance Queue", "Expiring Documents"],
          "layoutRules": ["card_container", "grid_row", "section_spacing"],
          "actionBindings": ["New Vendor Request", "View Compliance Queue"],
          "fallback": { "allowed": true, "rule": "Use styled static quick-link cards when icon-list navigation action binding is not safe." },
          "validationRules": ["section_exists", "action_bindings_present_or_deferred"],
          "passCondition": "Quick links are visible and any active buttons have valid navigation actions."
        },
        {
          "id": "recent_activity_timeline",
          "title": "Recent activity timeline",
          "status": "required",
          "controls": ["timeline-v", "collection", "container", "text", "dynamic-field"],
          "dataSources": ["Vendor Activity / History"],
          "requiredFields": ["Activity Date", "Activity Title", "Activity Type", "Actor", "Description"],
          "matchText": ["Recent Vendor Activity", "Activity Date", "Activity Title"],
          "layoutRules": ["card_container", "section_spacing"],
          "actionBindings": [],
          "itemTemplate": {
            "controls": ["timeline-v", "collection"],
            "minDynamicFields": 4,
            "requiredFields": ["Activity Date", "Activity Title", "Activity Type", "Actor"],
            "requiresActions": false
          },
          "fallback": { "allowed": true, "rule": "Use Collection timeline-style item cards if Vertical Timeline is not safe." },
          "validationRules": ["section_exists", "item_template_fields_present"],
          "passCondition": "Timeline or Collection shows activity date, title, type, actor, and description."
        }
      ]
    },
    {
      "id": "vendor_detail_view_page",
      "title": "Vendor Detail View Page",
      "type": "custom_view_form",
      "required": true,
      "sections": [
        {
          "id": "detail_header_summary_card",
          "title": "Header summary card",
          "status": "required",
          "controls": ["container", "grid", "text", "dynamic-field", "dynamic-user", "button"],
          "dataSources": ["Vendors"],
          "requiredFields": ["Vendor Name", "Risk Level", "Onboarding Status", "Compliance Status", "Owner"],
          "matchText": ["Vendor Name", "Risk Level", "Onboarding Status", "Compliance Status", "Owner"],
          "layoutRules": ["safe_padding", "card_container", "grid_row"],
          "actionBindings": ["Edit Vendor", "Add Document", "Add Task", "Start Review", "Print Summary"],
          "fallback": { "allowed": true, "rule": "Unsupported mutating actions must be inactive notes with reason; Print Summary and Edit Vendor should remain navigation where safe." },
          "validationRules": ["section_exists", "data_binding_present", "action_bindings_present_or_deferred"],
          "passCondition": "Header card shows key vendor fields and only safe active actions."
        },
        {
          "id": "onboarding_steps_bar",
          "title": "Onboarding steps bar",
          "status": "required",
          "controls": ["steps", "container", "text"],
          "dataSources": ["Vendors"],
          "requiredFields": ["Onboarding Status"],
          "matchText": ["Request Submitted", "Procurement Review", "Compliance Review", "Legal Review", "Finance Review", "Approved"],
          "layoutRules": ["section_spacing"],
          "actionBindings": [],
          "fallback": { "allowed": true, "rule": "Use styled status row if Steps bar is not safe." },
          "validationRules": ["section_exists", "six_stage_process_present"],
          "passCondition": "All six stages are visible in order."
        },
        {
          "id": "detail_tabs_or_sections",
          "title": "Tabs or sectioned layout",
          "status": "required",
          "controls": ["tabs", "container", "toggle", "divider"],
          "dataSources": ["Vendors"],
          "requiredFields": [],
          "matchText": ["Overview", "Documents", "Compliance", "Tasks", "History"],
          "layoutRules": ["safe_padding", "section_spacing"],
          "actionBindings": [],
          "fallback": { "allowed": true, "rule": "Use stacked titled sections if Tabs are not safe." },
          "validationRules": ["section_exists", "not_plain_text_only"],
          "passCondition": "Five detail areas are present as tabs or titled sections."
        },
        {
          "id": "overview_details",
          "title": "Overview details",
          "status": "required",
          "controls": ["container", "grid", "dynamic-field", "dynamic-user", "text"],
          "dataSources": ["Vendors"],
          "requiredFields": ["Vendor Type", "Country / Region", "Primary Contact", "Email", "Phone", "Payment Terms", "Annual Spend Estimate", "Budget Category", "Tax Review Status", "Bank Info Status", "Renewal Date"],
          "matchText": ["Vendor Type", "Country / Region", "Primary Contact", "Payment Terms"],
          "layoutRules": ["card_container", "grid_row", "section_spacing"],
          "actionBindings": [],
          "fallback": { "allowed": false, "rule": "Overview details are required." },
          "validationRules": ["section_exists", "data_binding_present", "card_structure_present"],
          "passCondition": "Profile and contract/payment fields are grouped into styled sections."
        },
        {
          "id": "documents_section",
          "title": "Documents section",
          "status": "required",
          "controls": ["data-list", "collection", "document", "container", "dynamic-file"],
          "dataSources": ["Vendor Documents"],
          "requiredFields": ["Document Type", "Review Status", "Expiry Date", "Reviewer", "Uploaded Date", "Notes"],
          "matchText": ["Documents", "Document Type", "Review Status", "Expiry Date"],
          "layoutRules": ["card_container", "section_spacing"],
          "actionBindings": ["Add Document"],
          "fallback": { "allowed": true, "rule": "If Document embed is not safe, use related documents table/cards and document the embed deferral." },
          "validationRules": ["section_exists", "data_binding_present", "data_table_columns_configured"],
          "passCondition": "Document table/cards exist with required columns and embed fallback is explicit when needed."
        },
        {
          "id": "compliance_section",
          "title": "Compliance section",
          "status": "required",
          "controls": ["collection", "data-list", "progress-circle", "alert", "container", "dynamic-field"],
          "dataSources": ["Compliance Reviews"],
          "requiredFields": ["Review Type", "Risk Score", "Severity", "Review Status", "Findings", "Required Actions", "Reviewer", "Review Date"],
          "matchText": ["Compliance", "Risk Score", "Required Actions", "Review Status"],
          "layoutRules": ["card_container", "grid_row", "section_spacing"],
          "actionBindings": ["Start Review"],
          "itemTemplate": {
            "controls": ["collection", "data-list"],
            "minDynamicFields": 4,
            "requiredFields": ["Review Type", "Risk Score", "Severity", "Review Status"],
            "requiresActions": false
          },
          "fallback": { "allowed": true, "rule": "Use Data table if review cards cannot safely bind; keep risk score and alert visible." },
          "validationRules": ["section_exists", "item_template_fields_present", "no_placeholder_content"],
          "passCondition": "Compliance section includes review context, risk score, status, and required actions."
        },
        {
          "id": "tasks_section",
          "title": "Tasks section",
          "status": "required",
          "controls": ["collection", "data-list", "container", "dynamic-field", "button"],
          "dataSources": ["Vendor Tasks"],
          "requiredFields": ["Task Name", "Task Type", "Assigned To", "Due Date", "Status", "Priority", "Notes"],
          "matchText": ["Tasks", "Task Name", "Assigned To", "Due Date", "Priority"],
          "layoutRules": ["card_container", "section_spacing"],
          "actionBindings": ["Add Task"],
          "itemTemplate": {
            "controls": ["collection", "data-list"],
            "minDynamicFields": 4,
            "requiredFields": ["Task Name", "Priority", "Status", "Assigned To", "Due Date"],
            "requiresActions": false
          },
          "fallback": { "allowed": true, "rule": "Use Data table if task cards or Mark Complete action binding is not safe." },
          "validationRules": ["section_exists", "item_template_fields_present", "action_bindings_present_or_deferred"],
          "passCondition": "Task section shows task fields and only safe active actions."
        },
        {
          "id": "history_timeline",
          "title": "History timeline",
          "status": "required",
          "controls": ["timeline-v", "collection", "container", "dynamic-field"],
          "dataSources": ["Vendor Activity / History"],
          "requiredFields": ["Activity Title", "Activity Type", "Activity Date", "Actor", "Description"],
          "matchText": ["History", "Activity Date", "Activity Title", "Actor"],
          "layoutRules": ["card_container", "section_spacing"],
          "actionBindings": [],
          "itemTemplate": {
            "controls": ["timeline-v", "collection"],
            "minDynamicFields": 4,
            "requiredFields": ["Activity Title", "Activity Type", "Activity Date", "Actor"],
            "requiresActions": false
          },
          "fallback": { "allowed": true, "rule": "Use Collection timeline-style fallback if Vertical Timeline is not safe." },
          "validationRules": ["section_exists", "item_template_fields_present"],
          "passCondition": "History section shows activity date, title, type, actor, and description."
        }
      ]
    },
    {
      "id": "new_vendor_request_form",
      "title": "New Vendor Request Form",
