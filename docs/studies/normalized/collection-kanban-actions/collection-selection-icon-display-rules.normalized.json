{
  "proof": "export-proven from Company Overview (2).yap; identifiers redacted or synthetic",
  "clickTarget": {
    "controlType": "container",
    "position": "absolute",
    "horizontal": "right",
    "action": "Select Items"
  },
  "uncheckedIconRule": {
    "icon": "fa-regular fa-square",
    "showWhen": "strIndex(var_SelectedItems, CurrentItem.ListDataID) < 0",
    "action": "style_regulation_action_show"
  },
  "checkedIconRule": {
    "icon": "fa-regular fa-square-check",
    "showWhen": "strIndex(var_SelectedItems, CurrentItem.ListDataID) >= 0",
    "action": "style_regulation_action_show"
  }
}
