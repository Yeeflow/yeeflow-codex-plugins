{
  "schema": "yeeflow-yapk-schema-standard-normalized",
  "case": "list_info",
  "source": "product-provided ypk-schema.json",
  "properties": [
    "ListID",
    "Title",
    "Description",
    "Status",
    "IsItemPerm",
    "IsVerRecord",
    "HasComment",
    "IconUrl",
    "TableCode",
    "Ext1",
    "Ext2",
    "Ext3",
    "Type",
    "Flags",
    "LayoutView",
    "Perms",
    "AdvancePerms",
    "Items"
  ],
  "typeEnum": [
    1,
    16,
    32,
    64,
    128,
    1024
  ],
  "rules": {
    "Flags": "bit flags; Show = 1 should be included"
  }
}
